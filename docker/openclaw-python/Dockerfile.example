# Example only, derived from the official OpenClaw runtime image published from
# the upstream Dockerfile.
#
# 仅为示例，基于 OpenClaw 官方 Dockerfile 构建出来的运行时镜像再做最小扩展。
#
# Why this file exists:
# - easier to maintain than forking the full upstream Dockerfile
# - keeps your customizations limited to Python runtime support
#
# 这样做的原因：
# - 比直接 fork 上游完整 Dockerfile 更容易维护
# - 你真正需要的自定义只有 Python 运行时支持

ARG OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw:latest
FROM ${OPENCLAW_BASE_IMAGE}

USER root

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      bash \
      python3 \
      python3-venv \
      ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Adjust USER if your base image expects a non-root runtime user.
# 如果你的基础镜像要求非 root 用户运行，请在这里改回对应用户。
USER node
