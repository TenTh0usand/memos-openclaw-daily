MEMOS_BASE_URL=https://memos.example.com
MEMOS_TOKEN=replace-with-your-memos-access-token
MEMOS_TIMEZONE=Asia/Shanghai
MEMOS_OUTPUT_ROOT=./runs
MEMOS_REPORT_VISIBILITY=PRIVATE
MEMOS_REPORT_TAG=daily-report
MEMOS_VERIFY_SSL=true
SMTP_HOST=smtp-relay.example.com
SMTP_PORT=2525
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=false
SMTP_USE_STARTTLS=false
SMTP_FROM=memos-bot@example.local
SMTP_TO=
SMTP_TIMEOUT_SECONDS=20
EMPTY_REMINDER_SUBJECT=Memos 今日还没有记录，记得随手记一下
EMPTY_REMINDER_BODY=今天的 Memos 还没有内容。你可以随手发一句话或一张照片，稍后系统会自动再尝试生成日报。
EMPTY_REMINDER_ONCE_PER_DAY=true
